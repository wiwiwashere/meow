{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["pip install -r requirements.txt"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["echo Build step complete"]
    }
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000"
  }
}